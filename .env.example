# =============================================================================
# Copy this file to `.env` and fill in values. Never commit `.env` (gitignored).
# Supabase: Project Settings → API (URL, anon key, service_role).
# =============================================================================

# -----------------------------------------------------------------------------
# NEW app project (current Wee / loveable) — used by Vite + Electron + Supabase JS
# -----------------------------------------------------------------------------
# Project URL
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# anon (public) key — safe to bundle in the renderer; respects RLS
VITE_SUPABASE_ANON_KEY=

# PostgREST schema for app tables (must match migrations + Dashboard → Data API → Exposed schemas)
VITE_SUPABASE_APP_SCHEMA=app_wee_v1

# -----------------------------------------------------------------------------
# NEW project — service_role (server / scripts ONLY — do not put in Vite client)
# -----------------------------------------------------------------------------
# Required for: `npm run migrate:media` (destination), some Node test scripts, full DB/Storage bypass.
# Same project as VITE_SUPABASE_URL; label in Dashboard is "service_role" secret.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL — one-time legacy migration (`npm run migrate:media`)
# Copy media-library files + media_library rows from OLD Supabase → new project above.
# -----------------------------------------------------------------------------
# OLD project URL (the legacy/ref project you are moving away from)
MIGRATE_SOURCE_SUPABASE_URL=https://OLD_PROJECT_REF.supabase.co

# OLD project service_role (not anon) — needed to list/download all Storage objects and read DB rows
MIGRATE_SOURCE_SERVICE_ROLE_KEY=

# Where the legacy `media_library` table lived (usually public)
# MIGRATE_SOURCE_DB_SCHEMA=public

# Storage bucket ids if yours differ from defaults
# MIGRATE_SOURCE_BUCKET=media-library
# MIGRATE_DEST_BUCKET=media-library

# -----------------------------------------------------------------------------
# OPTIONAL — seed local folder into new project (`npm run seed:media -- "C:\path\to\media-library"`)
# Exports from Supabase Storage download (e.g. .../media-library) — requires SUPABASE_SERVICE_ROLE_KEY.
# -----------------------------------------------------------------------------
# SEED_MEDIA_LOCAL_DIR=C:\path\to\media-library
